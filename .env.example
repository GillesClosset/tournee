# ─── PostgreSQL (Coolify-managed on VPS) ─────────────────────────────────────
# Connection string for the PostgreSQL instance.
# In Coolify: find in the PostgreSQL service's connection details.
DATABASE_URL=postgresql://user:password@localhost:5432/tournee

# ─── OpenRouteService ──────────────────────────────────────────────────────────
# The ORS API key is already provisioned for this project.
ORS_API_KEY=your_openrouteservice_key
ORS_BASE_URL=https://api.openrouteservice.org

# ─── Auth (Auth.js v5) ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=<random 32+ char string — generate with: openssl rand -base64 32>
# Email of the single admin user (Nath)
ADMIN_EMAIL=nath@example.com
# bcrypt hash of the admin password — generate once with bcryptjs
# Example: node -e "const b=require('bcryptjs'); b.hash('password',10).then(console.log)"
ADMIN_PASSWORD_HASH=<bcrypt hash of password — generate once with bcryptjs>
